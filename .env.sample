OPENROUTER_API_KEY=sk-...
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-...
GOOGLE_API_KEY=...

# Google Vertex AI (used when a judge_override sets use_vertex: true).
# Auth uses Application Default Credentials. Set up locally with
#   gcloud auth application-default login
#   gcloud config set project <PROJECT_ID>
#   gcloud auth application-default set-quota-project <PROJECT_ID>
# All three steps matter: the first authenticates, the second sets the
# default project for gcloud commands, and the third writes the quota
# project header that the google-genai SDK attaches to every Vertex
# call. If the second and third diverge, gcloud will warn about the
# mismatch and SDK calls will be billed/quota-charged against whichever
# project was set last by `set-quota-project`. As an alternative to ADC,
# export GOOGLE_APPLICATION_CREDENTIALS pointing to a service-account
# JSON. Use a project id that does not encode your identity; the
# resolved model string is recorded on every extraction row but the
# project id itself is not.
#
# Location: newer Gemini preview snapshots (e.g. gemini-3.1-pro-preview)
# are only deployed at the `global` endpoint on Vertex; regional
# locations such as us-central1 return 404 for those models. Stable
# Gemini 2.x snapshots accept regional endpoints as well. When in doubt,
# use `global`.
GOOGLE_VERTEX_PROJECT=
GOOGLE_VERTEX_LOCATION=global

# AWS Bedrock (used when a judge_override sets bedrock_fallback: true).
# Auth uses the boto3 default credential chain in this order:
#   1. AWS_ACCESS_KEY_ID + AWS_SECRET_ACCESS_KEY (+ AWS_SESSION_TOKEN)
#      env vars (set them here for a self-contained .env).
#   2. ~/.aws/credentials (set up via `aws configure`).
#   3. IAM role attached to the host (EC2, ECS, Lambda).
# The Anthropic judge falls over to Bedrock on a 429 from the direct
# Anthropic API; the model id used on Bedrock is configured per-judge
# in config.yaml under `bedrock_model_id` (e.g.
# `us.anthropic.claude-opus-4-6-v1:0`). Cross-region inference profiles
# (`us.` prefix) generally have higher and more flexible quota than
# region-local ids. AWS_REGION below selects the region the Bedrock
# client targets; pick one in which the chosen model id is available.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1